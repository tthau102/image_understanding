# =============================================================================
# ENVIRONMENT CONFIGURATION - Copy to .env and fill in your values
# =============================================================================

# =============================================================================
# APPLICATION & DATABASE  
# =============================================================================
APP_NAME=planogram-compliance
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration (for Review tab)
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=5432
DB_NAME=planogramdb
DB_USER=your-username
DB_PASSWORD=your-secure-password
DB_RESULT_TABLE=results

# =============================================================================
# S3 STORAGE (for Image Upload)
# =============================================================================
S3_BUCKET_NAME=your-s3-bucket
S3_FOLDER_PREFIX=project
S3_REGION=ap-southeast-1

# AWS Credentials
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# =============================================================================
# LABEL STUDIO INTEGRATION
# =============================================================================
LABEL_STUDIO_URL=http://your-labelstudio-server:8080
LABEL_STUDIO_API_TOKEN=your-api-token-here

# =============================================================================
# LAMBDA & PROCESSING
# =============================================================================
LAMBDA_FUNCTION_NAME=your-export-lambda-function-name

# File Processing
SUPPORTED_IMAGE_FORMATS=png,jpg,jpeg
MAX_FILE_SIZE_MB=200

# Security
SECRET_KEY=your-secret-key-for-session-management